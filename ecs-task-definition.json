{
  "comment": "Amazon ECS Task Definition for CodeSarthi (Fargate). Replace ACCOUNT_ID and REGION.",
  "family": "codesarthi",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/codesarthiTaskRole",
  "containerDefinitions": [
    {
      "name": "codesarthi",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/codesarthi:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV",               "value": "production"              },
        { "name": "AWS_REGION",             "value": "us-east-1"               },
        { "name": "BEDROCK_MODEL_ID",       "value": "anthropic.claude-3-5-haiku-20241022-v1:0" },
        { "name": "DYNAMODB_TABLE",         "value": "codesarthi-repos"        },
        { "name": "S3_BUCKET",              "value": "codesarthi-analyses"     }
      ],
      "secrets": [
        {
          "name": "GITHUB_TOKEN",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/codesarthi/github-token"
        },
        {
          "name": "AWS_ACCESS_KEY_ID",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/codesarthi/aws-access-key-id"
        },
        {
          "name": "AWS_SECRET_ACCESS_KEY",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/codesarthi/aws-secret-access-key"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/codesarthi",
          "awslogs-region":        "REGION",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:3000/ || exit 1"],
        "interval": 30,
        "timeout":  5,
        "retries":  3,
        "startPeriod": 60
      }
    }
  ]
}
