# ─────────────────────────────────────────────────────────────
# CodeSarthi — Environment Variables Template
# Copy to .env.local and fill in real values on the server
# ─────────────────────────────────────────────────────────────

# GitHub Token (for accessing private/public repos via API)
GITHUB_TOKEN=your_github_personal_access_token_here

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/codeSarthi?retryWrites=true&w=majority

# AI / LLM Keys
OPENAI_API_KEY=sk-proj-...
GOOGLE_API_KEY=AIzaSy...

# AWS Credentials (for Bedrock, DynamoDB, S3)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_BEARER_TOKEN_BEDROCK=...

# Optional: N8N Webhook
# N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/codesarthi-embeddings

# App Config
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1